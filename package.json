{
  "name": "zadiag-pwa",
  "private": true,
  "version": "0.7.2",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:design": "node scripts/check-design.mjs",
    "check": "npm run check:architecture && npm run check:design && npm run test && npm run build && npm run check:bundle && npm --prefix functions test",
    "check:full": "npm run check && npm run test:rules",
    "check:security": "corepack pnpm audit --prod --audit-level high && npm --prefix functions audit --omit=dev --audit-level=high",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "ionicons": "^8.0.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "firebase-tools": "^15.22.4",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "workbox-precaching": "^7.4.1"
  }
}
