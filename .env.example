# Public Firebase web configuration. These values identify the Firebase project;
# authorization is enforced by Firebase Rules and App Check, not by hiding them.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Public VAPID key used to create a standards-based Web Push subscription.
VITE_WEB_PUSH_PUBLIC_KEY=
